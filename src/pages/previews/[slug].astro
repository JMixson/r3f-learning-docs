---
import ExamplePreviewPage from '../../components/docs/ExamplePreviewPage';
import { exampleSlugs, getExample, type ExampleSlug } from '../../data/examples';

export function getStaticPaths() {
  return exampleSlugs.map((slug) => ({ params: { slug } }));
}

const previewSlug = exampleSlugs.includes(Astro.params.slug as ExampleSlug)
  ? (Astro.params.slug as ExampleSlug)
  : undefined;
const example = previewSlug ? getExample(previewSlug) : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{example ? `${example.meta.title} Preview` : 'Preview not found'}</title>
    <style>
      html,
      body {
        margin: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
        background: #020617;
      }

      body {
        font-family: ui-sans-serif, system-ui, sans-serif;
      }

      main {
        display: grid;
        width: 100%;
        height: 100%;
        place-items: center;
        color: #e2e8f0;
        background:
          radial-gradient(circle at top, rgb(56 189 248 / 0.16), transparent 55%),
          #020617;
      }

      p {
        margin: 0;
        padding: 1rem 1.2rem;
        border: 1px solid rgb(148 163 184 / 0.28);
        border-radius: 999px;
        background: rgb(15 23 42 / 0.8);
      }
    </style>
  </head>
  <body>
    {
      previewSlug ? (
        <ExamplePreviewPage client:only="react" slug={previewSlug} />
      ) : (
        <main>
          <p>This preview could not be found.</p>
        </main>
      )
    }
  </body>
</html>
