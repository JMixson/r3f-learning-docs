---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { CardGrid, LinkCard } from '@astrojs/starlight/components';

const frontmatter = {
  title: '404',
  description: 'The page you requested could not be found.',
  template: 'splash',
  editUrl: false,
} as const;
---

<StarlightPage frontmatter={frontmatter}>
  <div class="not-found-hero">
    <p class="not-found-tagline">
      The page you requested is missing, moved, or still being written. Use the links below to get back to the
      main learning path.
    </p>
  </div>

  <p>
    Sometimes the quickest recovery is to jump back into a section that already matches what you were trying to
    learn.
  </p>

  <CardGrid>
    <LinkCard
      title="Home"
      href="/"
      description="Return to the docs homepage and start from the main learning path."
    />
    <LinkCard
      title="Start Here"
      href="/start-here/why-r3f/"
      description="Rebuild the core mental model for reading React Three Fiber like familiar Three.js code."
    />
    <LinkCard
      title="Conversions"
      href="/conversions/scene-camera-renderer/"
      description="Browse direct translations from common Three.js setups into equivalent R3F patterns."
    />
    <LinkCard
      title="Reference"
      href="/reference/jsx-to-three-cheatsheet/"
      description="Look up JSX primitives, prop mappings, and common gotchas when a detail is blocking you."
    />
  </CardGrid>

  <p class="not-found-search-note">
    If you expected a page to exist, the search bar in the header is often the fastest way to find the renamed
    version.
  </p>
</StarlightPage>

<style>
  .not-found-hero {
    display: grid;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .not-found-hero h1 {
    margin: 0;
  }

  .not-found-tagline {
    margin: 0;
    font-size: clamp(1.1rem, 1rem + 0.4vw, 1.35rem);
    max-width: 42rem;
  }

  .not-found-search-note {
    margin-top: 1.5rem;
  }
</style>
