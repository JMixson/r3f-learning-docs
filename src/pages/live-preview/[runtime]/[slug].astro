---
import previewEntrypoint from '../../../entrypoints/live-preview.tsx?url&no-inline';
import { exampleSlugs, getExample, type ExampleSlug } from '../../../data/examples';

export function getStaticPaths() {
  return exampleSlugs.flatMap((slug) => [
    { params: { runtime: 'three', slug } },
    { params: { runtime: 'r3f', slug } },
  ]);
}

const runtime = Astro.params.runtime === 'r3f' ? 'r3f' : 'three';
const slug = Astro.params.slug as ExampleSlug;
const example = getExample(slug);
const title = `${example.meta.title} ${runtime === 'three' ? 'Three.js' : 'React Three Fiber'} Preview`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style>
      :root {
        color-scheme: dark;
      }

      html,
      body {
        margin: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
        background: #020617;
        font-family: ui-sans-serif, system-ui, sans-serif;
      }

      body[data-runtime='r3f'] #live-preview-root,
      #live-preview-root[data-runtime='three'] {
        width: 100%;
        height: 100%;
      }

      .preview-message {
        display: grid;
        place-items: center;
        width: 100%;
        height: 100%;
        padding: 1rem;
        box-sizing: border-box;
        color: #cbd5e1;
        text-align: center;
        background:
          radial-gradient(circle at top, rgba(56, 189, 248, 0.16), transparent 45%),
          #020617;
      }
    </style>
  </head>
  <body>
    <div id="live-preview-root" class="preview-message">Loading preview...</div>
    <script is:inline define:vars={{ runtime, slug }}>
      window.__LIVE_PREVIEW__ = { runtime, slug };
    </script>
    <script type="module" src={previewEntrypoint} is:inline></script>
  </body>
</html>
