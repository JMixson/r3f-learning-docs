---
import { Code, Tabs, TabItem } from '@astrojs/starlight/components';
import LivePreview from './LivePreview';

interface Props {
  title: string;
  slug: string;
  threeCode: string;
  r3fCode: string;
}

const { title, slug, threeCode, r3fCode } = Astro.props;
---

<section class="code-compare">
  <header class="section-header">
    <h2>{title}</h2>
    <p>Switch between the React Three Fiber and Three.js examples, then test the R3F result in the live preview below.</p>
  </header>

  <Tabs syncKey={`${slug}-runtime`}>
    <TabItem label="React Three Fiber">
      <Code
        code={r3fCode}
        lang="jsx"
        meta='title="React Three Fiber"'
      />
    </TabItem>

    <TabItem label="Three.js">
      <Code
        code={threeCode}
        lang="js"
        meta='title="Three.js"'
      />
    </TabItem>
  </Tabs>

  <LivePreview
    slug={slug}
    title={title}
  />
</section>

<style>
  .code-compare {
    margin: 2rem 0;
  }

  .section-header {
    margin-bottom: 1rem;
  }

  .section-header h2 {
    margin: 0;
  }

  .section-header p {
    margin: 0.5rem 0 0;
    color: var(--sl-color-gray-3);
  }
</style>
