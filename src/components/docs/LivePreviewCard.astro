---
interface Props {
  slug: string;
  runtime: 'three' | 'r3f';
  title: string;
  height?: number;
}

const { slug, runtime, title, height = 360 } = Astro.props;
const href = `/live-preview/${runtime}/${slug}/`;
---

<section class="preview-card">
  <div class="preview-header">
    <div>
      <h3>{title}</h3>
      <p>Run the local example in an isolated frame so the scene stays interactive without affecting the docs page.</p>
    </div>
    <a class="preview-link" href={href} target="_blank" rel="noreferrer">
      Open full preview
    </a>
  </div>

  <iframe
    src={href}
    title={title}
    loading="lazy"
    style={`height:${height}px;`}
    allow="accelerometer; ambient-light-sensor; camera; encrypted-media; geolocation; gyroscope; hid; microphone; midi; payment; usb; vr; xr-spatial-tracking"
  />
</section>

<style>
  .preview-card {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.75rem;
    padding: 1rem;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--sl-color-blue-low) 30%, transparent), transparent),
      var(--sl-color-black);
  }

  .preview-header {
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    align-items: start;
    margin-bottom: 1rem;
  }

  .preview-header h3 {
    margin: 0;
  }

  .preview-header p {
    margin: 0.4rem 0 0;
    color: var(--sl-color-gray-3);
  }

  .preview-link {
    white-space: nowrap;
    border: 1px solid var(--sl-color-accent);
    border-radius: 999px;
    padding: 0.5rem 0.85rem;
    text-decoration: none;
  }

  iframe {
    width: 100%;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.75rem;
    background: var(--sl-color-bg);
  }

  @media (max-width: 50rem) {
    .preview-header {
      flex-direction: column;
    }
  }
</style>
