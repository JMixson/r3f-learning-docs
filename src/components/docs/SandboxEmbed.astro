---
interface Props {
  url: string;
  title: string;
  height?: number;
}

const { url, title, height = 480 } = Astro.props;
const hasUrl = typeof url === 'string' && url.trim().length > 0;
---

<section class="sandbox-card">
  <div class="sandbox-header">
    <div>
      <h3>{title}</h3>
      <p>Open the runnable version when you want to compare the static snippet to an interactive playground.</p>
    </div>
    {hasUrl && (
      <a class="sandbox-link" href={url} target="_blank" rel="noreferrer">
        Open sandbox
      </a>
    )}
  </div>

  {
    hasUrl ? (
      <iframe
        src={url}
        title={title}
        loading="lazy"
        style={`height:${height}px;`}
        allow="accelerometer; ambient-light-sensor; camera; encrypted-media; geolocation; gyroscope; hid; microphone; midi; payment; usb; vr; xr-spatial-tracking"
      />
    ) : (
      <div class="placeholder">
        <p>This example is ready for a CodeSandbox URL, but none has been added yet.</p>
        <p>Fill in the matching `threeSandboxUrl` or `r3fSandboxUrl` field in the example's `meta.json` file when you publish the sandbox.</p>
      </div>
    )
  }
</section>

<style>
  .sandbox-card {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.75rem;
    padding: 1rem;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--sl-color-blue-low) 30%, transparent), transparent),
      var(--sl-color-black);
    margin: 1.5rem 0;
  }

  .sandbox-header {
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    align-items: start;
    margin-bottom: 1rem;
  }

  .sandbox-header h3 {
    margin: 0;
  }

  .sandbox-header p {
    margin: 0.4rem 0 0;
    color: var(--sl-color-gray-3);
  }

  .sandbox-link {
    white-space: nowrap;
    border: 1px solid var(--sl-color-accent);
    border-radius: 999px;
    padding: 0.5rem 0.85rem;
    text-decoration: none;
  }

  iframe,
  .placeholder {
    width: 100%;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.75rem;
    background: var(--sl-color-bg);
  }

  iframe {
    min-height: 20rem;
  }

  .placeholder {
    padding: 1rem;
    color: var(--sl-color-gray-2);
  }

  .placeholder p {
    margin: 0;
  }

  .placeholder p + p {
    margin-top: 0.75rem;
  }

  @media (max-width: 50rem) {
    .sandbox-header {
      flex-direction: column;
    }
  }
</style>
