---
interface Props {
  title?: string;
}

const { title = 'What Changed' } = Astro.props;
---

<section class="mapping-notes">
  <h2>{title}</h2>
  <div class="content">
    <slot />
  </div>
</section>

<style>
  .mapping-notes {
    border-left: 4px solid var(--sl-color-orange);
    padding: 1rem 1rem 1rem 1.25rem;
    border-radius: 0 0.75rem 0.75rem 0;
    background: color-mix(in srgb, var(--sl-color-orange-low) 55%, transparent);
    margin: 2rem 0;
  }

  .mapping-notes h2 {
    margin-top: 0;
  }

  .content :global(ul),
  .content :global(ol) {
    margin-bottom: 0;
  }
</style>
